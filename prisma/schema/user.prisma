model User {
  id        String      @id @default(uuid())

  name      String
  email     String      @unique
  password  String

  phone     String?

  role       Role       @default(CUSTOMER)
  status     UserStatus @default(ACTIVE)

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  gearItems GearItem[]

  rentals   RentalOrder[]

  reviews   Review[]
}